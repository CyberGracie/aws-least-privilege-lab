{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowViewBucketList",
      "Effect": "Allow",
      "Action": "s3:ListAllMyBuckets",
      "Resource": "*"
    },
    {
      "Sid": "AllowListPublicAssetsBucket",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::companypublic-assets"
    },
    {
      "Sid": "AllowReadPublicAssetsObjects",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::companypublic-assets/*"
    }
  ]
}
